}

function commanderLevelValue(){
  return Number(profile.commanderLevel) || commanderLevelFromXp(profile.xp || 0);
}
function techUnlocked(id){
  return !!(profile.tech && profile.tech[id]);
}
function unitIsUnlocked(unit){
  return !unit.tech || techUnlocked(unit.tech);
}
function unitUpgradeState(unitId){
  if(!profile.unitUpgrades[unitId]) profile.unitUpgrades[unitId] = { armor:0, precision:0, speed:0 };
  return profile.unitUpgrades[unitId];
}
function syncCommanderLevel(){
  const next = commanderLevelFromXp(profile.xp || 0);
  if(next > commanderLevelValue()) profile.techPoints = (profile.techPoints || 0) + (next - commanderLevelValue());
  profile.commanderLevel = next;
}
function addProgressRewards({money=0, gems=0, xp=0, pop=0, clanXp=0, clanWar=0, clanName=null}){
  if(money) profile.money += money;
  if(gems) profile.gems += gems;
  if(pop) profile.population += pop;
  if(xp) addCommanderXp(profile, xp);
  syncCommanderLevel();
  if(clanName){
    profile.__clanDelta = profile.__clanDelta || { xp:0, war:0 };
    profile.__clanDelta.xp += clanXp || 0;
    profile.__clanDelta.war += clanWar || 0;
  }
  checkAchievements();
  refreshHUD();
}
function checkAchievements(){
  if(!profile.achievements) profile.achievements = {};
  ACHIEVEMENT_DEFS.forEach(a=>{
    if(profile.achievements[a.id]) return;
    if(a.check(profile)){
      profile.achievements[a.id] = true;
      if(a.reward.money) profile.money += a.reward.money;
      if(a.reward.gems) profile.gems += a.reward.gems;
    }
  });
}
function prestigeAvailable(){
  return profile.levelsCompleted.every(Boolean) || commanderLevelValue() >= 15;
}
function doPrestige(){
  if(!prestigeAvailable()) return alert('Tu dois conquérir toute la carte ou atteindre le niveau 15 pour prestigier.');
  const bonus = 1 + Math.floor((profile.commanderLevel + profile.prestige) / 10);
  profile.prestige = (profile.prestige || 0) + 1;
  profile.prestigePoints = (profile.prestigePoints || 0) + bonus;
  profile.bonusPower += 100 * bonus;
  profile.money = 2000;
  profile.gems = 25;
  profile.population = 100;
  profile.xp = 0;
  profile.commanderLevel = 1;
  profile.techPoints = 0;
  profile.levelsCompleted = new Array(LEVEL_COUNT).fill(false);
  profile.questsClaimed = {};
  profile.unitUpgrades = {};
  profile.tech = {};
  profile.general = null;
  profile.bank = { deposited: 0, lastTick: Date.now() };
  profile.battleWins = 0;
  profile.battleLosses = 0;
  afterChange();
}
function spendTechPoint(techId){
  const tech = TECH_DEFS.find(t=>t.id===techId);
  if(!tech) return;
  if(techUnlocked(techId)) return;
  if((profile.techPoints||0) < tech.cost) return alert('Pas assez de points de technologie.');
  profile.techPoints -= tech.cost;
  profile.tech[techId] = true;
  checkAchievements();
  afterChange();
}
function recruitGeneral(generalId){
  const def = GENERAL_DEFS.find(g=>g.id===generalId);
  if(!def) return;
  if(profile.general === generalId) return;
  if(profile.money < def.cost) return alert('Pas assez d’argent.');
  profile.money -= def.cost;
  profile.general = generalId;
  afterChange();
}
function bankDeposit(amount){
  const value = Math.max(1, Math.floor(amount));
  if(profile.money < value) return false;
  profile.money -= value;
  profile.bank.deposited += value;
  profile.bank.lastTick = Date.now();
  afterChange();
  return true;
}
function bankWithdraw(amount){
  const value = Math.max(1, Math.floor(amount));
  if(profile.bank.deposited < value) return false;
  profile.bank.deposited -= value;
  profile.money += value;
  profile.bank.lastTick = Date.now();
  afterChange();
  return true;
}
function upgradeUnit(unitId, field){
  const up = unitUpgradeState(unitId);
  const price = field === 'armor' ? 600 : (field === 'precision' ? 650 : 500);
  if(profile.money < price) return alert('Pas assez d’argent.');
  profile.money -= price;
  up[field] = (up[field] || 0) + 1;
  afterChange();
}
function rotatingStock(key, max){
  const bucket = Math.floor(Date.now() / 300000);
  let hash = bucket;
  const token = `${key}:${bucket}`;
  for(const ch of token){ hash = (hash * 31 + ch.charCodeAt(0)) % 1000003; }
  return hash % (max + 1);
}
