/* ============================ PROGRESSION ============================ */
function renderProgress(){
  const el = document.getElementById('progressBody');
  const level = commanderLevelValue();
  const prevThreshold = Math.pow(Math.max(0, level - 1), 2) * 250;
  const nextThreshold = Math.pow(level, 2) * 250;
  const gained = Math.max(0, (profile.xp || 0) - prevThreshold);
  const needed = Math.max(1, nextThreshold - prevThreshold);
  const pct = Math.min(100, Math.round((gained / needed) * 100));
  let html = `<div class="section-title display">Progrès du commandant</div>
    <div class="progress-grid">
      <div class="panel-box">
        <div class="statline"><span>Niveau</span><b>${level}</b></div>
        <div class="statline"><span>XP</span><b>${Math.floor(profile.xp || 0)} / ${nextThreshold}</b></div>
        <div class="statline"><span>Prestige</span><b>${profile.prestige || 0}</b></div>
        <div class="statline"><span>Points tech</span><b>${profile.techPoints || 0}</b></div>
        <div class="statline"><span>Général</span><b>${profile.general || 'aucun'}</b></div>
        <div class="statline"><span>Revenu banque</span><b>${Math.floor(profile.bank && profile.bank.deposited || 0)}</b></div>
