async function renderClan(){
  const el = document.getElementById('clanBody');
  el.innerHTML = `<div class="section-title display">Clan</div><div id="clanBox">Chargement…</div>`;
  const clans = await getClans();
  const box = document.getElementById('clanBox');
  if(profile.clan && clans[profile.clan]){
    const c = clans[profile.clan];
    const lb = await fetchLeaderboard();
    const popOf = n => { const e = lb.find(x=>x.name===n); return e?e.population:'?'; };
    const missions = Array.isArray(c.missions) ? c.missions : [];
    const messages = await fetchClanChat(profile.clan);
    box.innerHTML = `
      <h3 style="margin-top:0;">${c.name}</h3>
      <p style="color:var(--paper-dim);font-size:13px;">${c.members.length} membre(s) · Niveau ${c.level || 1} · XP ${c.xp || 0} · Guerre ${c.warPoints || 0}</p>
      <div class="section-title" style="font-size:20px;margin-top:14px;">Membres</div>
      <div id="clanList">${c.members.map(m=>`<div class="member"><span>${m}${m===profile.name?' (toi)':''}</span><span>${popOf(m)} 👥</span></div>`).join('')}</div>
      <div class="section-title" style="font-size:20px;margin-top:14px;">Missions de clan</div>
      <div class="list">${missions.map(m=>`<div class="list-item">
        <div class="list-item-head"><div><span class="tag">${m.progress||0}/${m.target||0}</span> ${m.txt}</div>
        <div>${m.claimed ? '<span style="color:var(--green);">Réclamée</span>' : ((m.progress||0) >= (m.target||0) ? `<button class="small-btn" data-clan-mission-claim="${m.id}">Réclamer</button>` : '<span style="color:var(--paper-dim);">En cours</span>')}</div></div>
      </div>`).join('')}</div>
      <div class="section-title" style="font-size:20px;margin-top:14px;">Chat de clan</div>
      <div class="chat-box" id="clanChatBox">${messages.length ? messages.map(msg=>`<div class="chat-msg"><div class="who">${msg.sender}<span class="when">${new Date(msg.createdAt).toLocaleTimeString()}</span></div><div>${msg.text}</div></div>`).join('') : '<div style="color:var(--paper-dim);">Aucun message.</div>'}</div>
      <div class="field-row" style="margin-top:10px;">
        <input id="clanChatInput" placeholder="Écrire un message au clan" style="flex:1;">
        <button class="small-btn" id="sendClanMsgBtn">Envoyer</button>
      </div>
      <button class="btn danger" id="leaveClan">Quitter le clan</button>
    `;
    document.getElementById('leaveClan').onclick = async ()=>{
      clans[profile.clan].members = clans[profile.clan].members.filter(m=>m!==profile.name);
      if(clans[profile.clan].members.length===0) delete clans[profile.clan];
      const ok = await saveClans(clans);
      if(ok){
        profile.clan = null;
        afterChange();
      }
      renderClan();
    };
    document.getElementById('sendClanMsgBtn').onclick = async ()=>{
      try{
        const text = document.getElementById('clanChatInput').value.trim();
        if(!text) return;
        await sendClanChat(profile.clan, text);
        renderClan();
      }catch(e){ alert(e.message || 'Impossible d’envoyer le message.'); }
    };
    el.querySelectorAll('[data-clan-mission-claim]').forEach(b=>b.onclick=async ()=>{
      try{
        const mission = missions.find(m=>m.id === b.dataset.clanMissionClaim);
        if(!mission || mission.claimed || (mission.progress||0) < (mission.target||0)) return;
        mission.claimed = true;
        if(mission.reward.money) profile.money += mission.reward.money;
        if(mission.reward.gems) profile.gems += mission.reward.gems;
        await saveClans(clans);
        afterChange();
        renderClan();
      }catch(e){ alert(e.message || 'Impossible de réclamer cette mission.'); }
    });
  } else {
    const clanNames = Object.keys(clans);
    box.innerHTML = `
      <p style="font-size:13px;color:var(--paper-dim);">Rejoins un clan existant ou crée le tien. Visible par tout le monde, y compris ton frère.</p>
      <div style="display:flex;gap:8px;margin:10px 0;">
        <input id="newClanName" placeholder="Nom du nouveau clan" style="flex:1;padding:8px;background:var(--ink);border:1px solid var(--line);color:var(--paper);border-radius:3px;">
        <button class="btn" style="width:auto;margin:0;padding:8px 14px;font-size:16px;" id="createClanBtn">Créer</button>
      </div>
      <div class="section-title" style="font-size:20px;margin-top:18px;">Clans existants</div>
      ${clanNames.length===0 ? '<p style="font-size:13px;color:var(--paper-dim);">Aucun clan pour l\'instant — sois le premier.</p>' :
        clanNames.map(n=>`<div class="member" style="margin-bottom:6px;"><span>${n} (${clans[n].members.length})</span>
          <button data-join="${n}" style="background:var(--khaki);border:none;color:var(--ink);padding:4px 10px;border-radius:3px;cursor:pointer;font-size:12px;">Rejoindre</button></div>`).join('')}
    `;
    document.getElementById('createClanBtn').onclick = async ()=>{
      const name = document.getElementById('newClanName').value.trim();
      if(!name) return;
      if(clans[name]){ alert('Ce nom de clan existe déjà.'); return; }
      const btn = document.getElementById('createClanBtn');
      btn.disabled = true; btn.textContent = '...';
      clans[name] = {name, members:[profile.name], created:Date.now(), level:1, xp:0, warPoints:0, missions:[
        { id: 'm1', txt: 'Gagner 5 batailles', reward: { gems: 10 }, progress: 0, target: 5, claimed: false },
        { id: 'm2', txt: 'Construire 10 usines en équipe', reward: { money: 1000 }, progress: 0, target: 10, claimed: false },
        { id: 'm3', txt: 'Réunir 20 membres de puissance', reward: { gems: 25 }, progress: 0, target: 20, claimed: false },
      ], chat: []};
      const ok = await saveClans(clans);
      if(ok){
        profile.clan = name;
        afterChange();
      }
      renderClan();
    };
    el.querySelectorAll('[data-join]').forEach(b=>b.onclick=async ()=>{
      const n = b.dataset.join;
      b.disabled = true; b.textContent = '...';
      if(!clans[n].members.includes(profile.name)) clans[n].members.push(profile.name);
      const ok = await saveClans(clans);
      if(ok){
        profile.clan = n;
        afterChange();
      }
      renderClan();
    });
  }
}

async function updateClanProgress(delta){
  if(!profile.clan) return;
  const clans = await getClans();
  const clan = clans[profile.clan];
  if(!clan) return;
  const progress = delta || {};
  clan.xp = (clan.xp || 0) + (progress.xp || 0);
  clan.warPoints = (clan.warPoints || 0) + (progress.war || 0);
  clan.level = Math.max(1, Math.floor((clan.xp || 0) / 250) + 1);
  clan.missions = Array.isArray(clan.missions) ? clan.missions : [];
  clan.missions.forEach(m=>{
    if(m.id === 'm1' && progress.battle) m.progress = (m.progress || 0) + progress.battle;
    if(m.id === 'm2' && progress.factory) m.progress = (m.progress || 0) + progress.factory;
    if(m.id === 'm3' && progress.power) m.progress = Math.max(m.progress || 0, Math.floor(progress.power / 1000));
  });
  clans[profile.clan] = clan;
  await saveClans(clans);
}

/* ============================ LEADERBOARD ============================ */
async function renderBoard(){
  const el = document.getElementById('boardBody');
  el.innerHTML = `<div class="section-title display">Classement général</div><p style="color:var(--paper-dim);font-size:13px;">Mis à jour à chaque victoire. Partagé entre tous les commandants.</p><div id="lbWrap">Chargement…</div>`;
  await pushToLeaderboard();
  const entries = await fetchLeaderboard();
  const wrap = document.getElementById('lbWrap');
  if(entries.length===0){ wrap.innerHTML = '<p>Aucune donnée pour l\'instant.</p>'; return; }
  let html = `<table class="lb"><tr><th>#</th><th>Commandant</th><th>Niveau</th><th>Prestige</th><th>Clan</th><th>Population</th><th>Puissance</th></tr>`;
  entries.forEach((e,i)=>{
    html += `<tr class="${e.name===profile.name?'me':''}"><td class="rank">${i+1}</td><td>${e.name}</td><td>${e.level || 1}</td><td>${e.prestige || 0}</td><td>${e.clan||'—'}</td><td>${e.population}</td><td>${e.power||0}</td></tr>`;
  });
  html += `</table>`;
  wrap.innerHTML = html;
}

/* ============================ HUD / TICK ============================ */
function refreshHUD(){
  document.getElementById('statPop').textContent = profile.population;
  document.getElementById('statMoney').textContent = Math.floor(profile.money);
  document.getElementById('statGem').textContent = profile.gems;
  document.getElementById('statLevel').textContent = commanderLevelValue();
  document.getElementById('statPower').textContent = computePower(profile);
  
  // Afficher/masquer le bouton admin
  const adminBtn = document.getElementById('adminBtn');
  if(adminBtn){
    adminBtn.style.display = profile.name === 'GalacticGogo9' ? 'block' : 'none';
  }
}
function afterChange(){ refreshHUD(); saveProfile(); }

function tickEconomy(){
  profile = syncProfileEconomy(profile);
}
setInterval(()=>{
  if(!profile) return;
  tickEconomy();
  refreshHUD();
  saveProfile();
}, 4000);

/* ============================ LOGIN / INIT ============================ */
document.getElementById('loginBtn').onclick = ()=> doLogin('login');
document.getElementById('registerBtn').onclick = ()=> doLogin('register');
document.getElementById('logoutBtn').onclick = ()=> logout();
document.getElementById('nameInput').addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin('login'); });
document.getElementById('passwordInput').addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin('login'); });
document.getElementById('difficultySelect').value = 'normal';
document.getElementById('difficultySelect').onchange = ()=>{
  if(!profile) return;
  profile.battleDifficulty = document.getElementById('difficultySelect').value;
  afterChange();
};
document.getElementById('bossFightBtn').onclick = ()=> launchBossBattle();

async function doLogin(mode){
  const val = document.getElementById('nameInput').value.trim();
  const password = document.getElementById('passwordInput').value;
  if(!val || !password) return setLoginStatus('Renseigne le nom et le mot de passe.', 'var(--red)');
  try{
    setLoginStatus(mode === 'register' ? 'Création du compte...' : 'Connexion...', 'var(--paper-dim)');
    const res = await apiRequest(mode === 'register' ? '/api/register' : '/api/login', {
      method: 'POST',
      body: { name: val, password },
    });
    authToken = res.token;
    localStorage.setItem('oa_token', authToken);
    profile = mergeProfile(res.profile || await loadProfile(val), val);
    username = profile.name;
  }catch(e){
    setLoginStatus(e.message || 'Échec de connexion.', 'var(--red)');
    return;
  }
  tickEconomy();
  document.getElementById('difficultySelect').value = profile.battleDifficulty || 'normal';
  setLoginStatus('', 'var(--paper-dim)');
  document.getElementById('loginModal').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  initMap();
  refreshHUD();
  pushToLeaderboard();
  saveProfile();
}

async function restoreSession(){
  if(!authToken) return false;
  try{
    const res = await apiRequest('/api/me');
    profile = mergeProfile(res.profile, res.profile.name);
    username = profile.name;
    tickEconomy();
    document.getElementById('difficultySelect').value = profile.battleDifficulty || 'normal';
    document.getElementById('loginModal').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    initMap();
    refreshHUD();
    pushToLeaderboard();
    return true;
  }catch(e){
    authToken = '';
    localStorage.removeItem('oa_token');
    return false;
  }
}

async function logout(){
  try{
    if(authToken) await apiRequest('/api/logout', { method: 'POST' });
  }catch(e){}
  authToken = '';
  profile = null;
  username = null;
  localStorage.removeItem('oa_token');
  document.getElementById('app').style.display = 'none';
  document.getElementById('loginModal').style.display = 'flex';
  document.getElementById('nameInput').value = '';
  document.getElementById('passwordInput').value = '';
  setLoginStatus('Déconnecté.', 'var(--paper-dim)');
}

restoreSession();
</script>
