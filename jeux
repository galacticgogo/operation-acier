async function apiRequest(path, options={}){
  const headers = Object.assign({}, options.headers || {});
  if(!(options.body instanceof FormData) && options.body !== undefined) headers['Content-Type'] = 'application/json';
  if(authToken) headers.Authorization = `Bearer ${authToken}`;
  const res = await fetch(path, {
    method: options.method || 'GET',
    headers,
    body: options.body instanceof FormData ? options.body : (options.body !== undefined ? JSON.stringify(options.body) : undefined),
  });
  const payload = await res.json().catch(()=>null);
  if(!res.ok) throw new Error(payload && payload.error ? payload.error : 'Erreur réseau');
  return payload;
}

function totalUnits(p){ return UNIT_DEFS.reduce((s,u)=>s+p.units[u.id],0); }
function computePower(p){
  let pw = p.bonusPower||0;
  UNIT_DEFS.forEach(u=>{
    const owned = p.units[u.id] || 0;
    const upgrades = p.unitUpgrades && p.unitUpgrades[u.id] ? p.unitUpgrades[u.id] : { armor:0, precision:0, speed:0 };
    const upgradeBonus = owned * ((upgrades.armor||0)*2 + (upgrades.precision||0)*3 + (upgrades.speed||0));
    pw += owned*u.power + upgradeBonus;
  });
  if(p.general === 'tactician') pw *= 1.08;
  if(p.general === 'admiral') pw += ((p.units.submarine||0) + (p.units.carrier||0)) * 12;
  if(p.tech && p.tech.precision) pw *= 1.08;
  pw += (p.prestige||0) * 75;
  return Math.round(pw);
}
function factoryIncomePerSecond(p){
  let inc=0; FACTORY_DEFS.forEach(f=> inc += p.factories[f.id]*f.income );
  if(p.general === 'economist') inc *= 1.15;
  if(p.tech && p.tech.logistics) inc *= 1.1;
  return inc;
}
function defaultProfile(name){
  return {
    name, clan:null, money:2000, gems:25, population:100,
    xp:0, commanderLevel:1, prestige:0, prestigePoints:0, techPoints:0,
    tech:{}, achievements:{}, unitUpgrades:{}, general:null,
    bank:{deposited:0, lastTick:Date.now()}, battleDifficulty:'normal',
    battleWins:0, battleLosses:0,
    units:{infantry:0,armor:0,heavy:0,jet:0,carrier:0,drone:0,artillery:0,helicopter:0,submarine:0,missile:0},
    factories:{f1:0,f2:0,f3:0},
    bonusPower:0,
    levelsCompleted: new Array(LEVEL_COUNT).fill(false),
    questsClaimed:{},
    lastTick: Date.now(),
  };
}
function commanderLevelFromXp(xp){
  return Math.max(1, Math.floor(Math.sqrt(Math.max(0, xp||0)/250))+1);
}
function mergeProfile(profile, name){
  const base = defaultProfile(name);
  const source = profile || {};
  const merged = {
    ...base,
    ...source,
    name: source.name || name,
    clan: source.clan || null,
    units: { ...base.units, ...(source.units || {}) },
    factories: { ...base.factories, ...(source.factories || {}) },
    bank: { ...base.bank, ...(source.bank || {}) },
    tech: { ...(source.tech || {}) },
    achievements: { ...(source.achievements || {}) },
    unitUpgrades: { ...(source.unitUpgrades || {}) },
    levelsCompleted: Array.from({ length: LEVEL_COUNT }, (_, index) => !!(source.levelsCompleted && source.levelsCompleted[index])),
    questsClaimed: { ...(source.questsClaimed || {}) },
    xp: Number(source.xp) || 0,
    commanderLevel: Number(source.commanderLevel) || commanderLevelFromXp(Number(source.xp) || 0),
    prestige: Number(source.prestige) || 0,
    prestigePoints: Number(source.prestigePoints) || 0,
    techPoints: Number(source.techPoints) || 0,
    general: source.general || null,
    battleDifficulty: source.battleDifficulty || 'normal',
    battleWins: Number(source.battleWins) || 0,
    battleLosses: Number(source.battleLosses) || 0,
    lastTick: Number(source.lastTick) || Date.now(),
  };
  const computedLevel = commanderLevelFromXp(merged.xp);
  if (computedLevel > merged.commanderLevel) {
    merged.techPoints += computedLevel - merged.commanderLevel;
    merged.commanderLevel = computedLevel;
  }
  return merged;
}
function addCommanderXp(profile, amount){
  const before = commanderLevelFromXp(profile.xp || 0);
  profile.xp = (profile.xp || 0) + Math.max(0, amount || 0);
  const after = commanderLevelFromXp(profile.xp);
  if(after > before) profile.techPoints = (profile.techPoints || 0) + (after-before);
  profile.commanderLevel = after;
}
function syncProfileEconomy(profile){
  const now = Date.now();
  const merged = mergeProfile(profile, profile.name);
  const elapsed = Math.max(0, now - (merged.lastTick || now));
  if(elapsed > 0){
    const income = factoryIncomePerSecond(merged) * (elapsed/1000);
    merged.money += income;
    if(merged.bank.deposited > 0){
      const bankElapsed = Math.max(0, now - (merged.bank.lastTick || now));
      const rate = 0.0006 + ((merged.tech && merged.tech.logistics) ? 0.0002 : 0);
      merged.bank.deposited += merged.bank.deposited * rate * (bankElapsed/60000);
      merged.bank.lastTick = now;
    }
    merged.lastTick = now;
  }
  merged.commanderLevel = commanderLevelFromXp(merged.xp);
  return merged;
}
async function loadProfile(name){
  try{
    if(!authToken) return defaultProfile(name);
    const res = await apiRequest('/api/me');
    if(res && res.profile){
      return mergeProfile(res.profile, res.profile.name || name);
    }
  }catch(e){}
  return defaultProfile(name);
}
