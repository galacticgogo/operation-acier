        </div>
        <div style="font-size:12px;color:var(--paper-dim);margin-top:6px;">${pct}% vers le prochain niveau</div>
        <button class="btn" id="prestigeBtn" ${prestigeAvailable() ? '' : 'disabled'}>Prestige</button>
      </div>
      <div class="panel-box">
        <div class="statline"><span>Victoire/défaite</span><b>${profile.battleWins || 0} / ${profile.battleLosses || 0}</b></div>
        <div class="statline"><span>Difficulté</span><b>${profile.battleDifficulty || 'normal'}</b></div>
        <div class="statline"><span>Bonus permanent</span><b>+${Math.round((profile.prestige || 0) * 75)} puissance</b></div>
        <div class="statline"><span>Bonus généraux</span><b>${profile.general ? 'actif' : 'aucun'}</b></div>
        <button class="btn secondary" id="bossFightBtn2">Boss mondial</button>
        <button class="btn secondary" id="refreshProgressBtn">Rafraîchir</button>
      </div>
    </div>`;

  html += `<div class="mini-title">Arbre de technologies</div><div class="tech-grid">`;
  TECH_DEFS.forEach(tech=>{
    const owned = techUnlocked(tech.id);
    const canBuy = !owned && (profile.techPoints || 0) >= tech.cost;
